[Unit]
Description=Scraper API Service
After=network.target postgresql.service
Requires=postgresql.service

[Service]
User=scraperapi
Group=scraperapi
WorkingDirectory=/opt/scraper-api-service
Environment="PATH=/opt/scraper-api-service/.venv/bin"
ExecStart=/opt/scraper-api-service/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always

[Install]
WantedBy=multi-user.target
