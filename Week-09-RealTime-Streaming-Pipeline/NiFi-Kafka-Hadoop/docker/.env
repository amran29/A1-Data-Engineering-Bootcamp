# ==========================================
# Docker Images Versions
# ==========================================
NIFI_VERSION=latest
CONFLUENT_VERSION=7.3.2
HADOOP_VERSION=latest
KAFKA_UI_VERSION=latest

# ==========================================
# Apache NiFi Settings
# ==========================================
# نستخدم 8443 لأنه المنفذ الذي نجح معك سابقاً في وضع HTTPS
NIFI_HTTPS_PORT=8443
NIFI_USER=admin
# تأكد أن كلمة المرور قوية وطويلة (أكثر من 12 حرفاً)
NIFI_PASSWORD=SuperSecretNiFiPass123!

# ==========================================
# Kafka & Zookeeper Settings
# ==========================================
ZOOKEEPER_PORT=2181
KAFKA_PORT=9092
KAFKA_UI_PORT=8090

# ==========================================
# HDFS Settings (Optional Ports)
# ==========================================
# هذه المنافذ اختيارية لأن NiFi سيتصل بـ Hadoop داخلياً عبر الشبكة
HDFS_WEB_PORT=9870
HDFS_IPC_PORT=8020